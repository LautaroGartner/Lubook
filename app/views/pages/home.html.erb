<% content_for :title, "Home" %>

<div class="mb-6 bg-white border border-stone-200 rounded p-6">
  <%= form_with model: Post.new, url: posts_path, multipart: true, class: "space-y-3" do |f| %>
    <%= f.text_area :body, rows: 3, placeholder: "What's happening?",
          class: "w-full px-3 py-2 border border-stone-300 rounded resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>
    <div class="flex items-center justify-between">
      <label class="inline-flex items-center gap-2 px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded cursor-pointer transition"
             data-controller="upload">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span data-upload-label>Add image</span>
        <%= f.file_field :image, accept: "image/jpeg,image/png,image/webp,image/gif",
              class: "hidden", data: { action: "change->upload#preview" } %>
      </label>
      <%= f.submit "Post",
            class: "px-5 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer text-sm font-medium" %>
    </div>
  <% end %>
</div>

<% if @posts.any? %>
  <div class="space-y-6">
    <%= render @posts %>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <div class="bg-white border border-stone-200 rounded p-12 text-center text-stone-500">
    <p class="text-lg font-serif text-stone-700 mb-2">It's quiet here.</p>
    <p class="text-sm">Post something above, or wander over to <%= link_to "People", users_path, class: "text-rose-600 hover:text-rose-700 transition-colors" %> and find some friends.</p>
  </div>
<% end %>