<% content_for :title, "Home" %>

<div class="mb-6 bg-white border border-stone-200 rounded p-6">
  <%= form_with model: Post.new, url: posts_path, multipart: true, class: "space-y-3" do |f| %>
    <%= f.text_area :body, rows: 3, placeholder: "What's happening?",
          class: "w-full px-3 py-2 border border-stone-300 rounded resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>

    <%= render "posts/form",
          form: f,
          submit_button: f.submit("Post", class: "px-5 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer text-sm font-medium shrink-0") %>
  <% end %>
</div>

<% if @posts.any? %>
  <div class="space-y-6">
    <%= render @posts %>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <div class="bg-white border border-stone-200 rounded p-12 text-center text-stone-500">
    <p class="text-lg font-serif text-stone-700 mb-2">It's quiet here.</p>
    <p class="text-sm">Post something above, or wander over to <%= link_to "People", users_path, class: "text-rose-600 hover:text-rose-700 transition-colors" %> and find some friends.</p>
  </div>
<% end %>
