<% content_for :title, "Chats" %>

<div class="grid gap-6 lg:grid-cols-[20rem,1fr]">
  <aside class="bg-white border border-stone-200 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-stone-200">
      <h1 class="text-xl font-serif font-semibold text-stone-900">Chats</h1>
    </div>

    <div class="px-4 py-4 border-b border-stone-100 bg-stone-50/70">
      <%= form_with url: conversations_path, method: :get, class: "space-y-3" do |f| %>
        <%= f.text_field :q, value: @chat_query, placeholder: "Find someone to message...",
              class: "w-full px-3 py-2 border border-stone-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-stone-400" %>
        <% if @chat_candidates.any? %>
          <div class="space-y-2">
            <% @chat_candidates.limit(5).each do |user| %>
              <div class="flex items-center justify-between gap-3 rounded-lg bg-white border border-stone-200 px-3 py-2">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-stone-900 truncate"><%= user.profile&.display_name.presence || user.username %></p>
                  <p class="text-xs text-stone-500 truncate">@<%= user.username %></p>
                </div>
                <%= button_to "Message", conversations_path(user_id: user.id),
                      class: "px-3 py-1.5 text-sm bg-stone-900 text-white rounded-full hover:bg-stone-800 transition-colors" %>
              </div>
            <% end %>
          </div>
        <% elsif @chat_query.present? %>
          <p class="text-xs text-stone-500">No connected users match that search.</p>
        <% end %>
      <% end %>
    </div>

    <% if @conversations.any? %>
      <div class="divide-y divide-stone-100">
        <% @conversations.each do |conversation| %>
          <% other_user = conversation.other_participant_for(current_user) %>
          <% unread = conversation.conversation_participants.find { |participant| participant.user_id == current_user.id }&.last_read_at %>
          <% latest_message = conversation.messages.max_by(&:created_at) %>
          <%= link_to conversation_path(conversation),
                class: "block px-4 py-3 hover:bg-stone-50 transition-colors" do %>
            <div class="flex items-center justify-between gap-3">
              <p class="font-semibold text-stone-900"><%= other_user&.profile&.display_name.presence || other_user&.username %></p>
              <% if latest_message && (unread.blank? || latest_message.created_at > unread) %>
                <span class="inline-flex w-2.5 h-2.5 rounded-full bg-rose-500"></span>
              <% end %>
            </div>
            <% if latest_message %>
              <% preview_text =
                   if latest_message.body.present?
                     truncate(latest_message.body, length: 90)
                   elsif latest_message.image.attached?
                     "Sent a photo"
                   end %>
              <% if preview_text.present? %>
                <p class="mt-1 text-sm text-stone-500 line-clamp-2"><%= preview_text %></p>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="p-6 text-sm text-stone-500">
        Start a chat with someone you already follow or who follows you back.
      </div>
    <% end %>
  </aside>

  <section class="bg-white border border-dashed border-stone-300 rounded-xl p-8 text-center text-stone-500 hidden lg:block">
    <p class="text-lg font-serif text-stone-700">Pick a conversation</p>
    <p class="mt-2 text-sm">Messages stay private between you and the other person.</p>
  </section>
</div>
