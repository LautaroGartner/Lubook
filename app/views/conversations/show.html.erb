<% content_for :title, @other_participant&.username || "Chat" %>

<section class="max-w-4xl mx-auto bg-white border border-stone-200 rounded-xl flex flex-col min-h-[34rem]" data-controller="lightbox message-form">
  <header class="px-6 py-4 border-b border-stone-200">
    <div class="flex items-center justify-between gap-4">
      <div>
        <%= link_to conversations_path, class: "inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-stone-400 hover:text-stone-700 transition-colors mb-2" do %>
          <span>←</span>
          <span>Back to chats</span>
        <% end %>
        <h2 class="text-xl font-serif font-semibold text-stone-900">
          <%= @other_participant&.profile&.display_name.presence || @other_participant&.username %>
        </h2>
        <p class="text-sm text-stone-500">@<%= @other_participant&.username %></p>
        <%= render "conversations/presence", other_participant: @other_participant, conversation: @conversation %>
      </div>
      <% if @other_participant %>
        <%= link_to "View profile", user_path(@other_participant),
              class: "text-sm text-rose-700 hover:text-rose-800 transition-colors" %>
      <% end %>
    </div>
  </header>

  <%= turbo_stream_from [@conversation, current_user] %>
  <div id="conversation_messages"
       data-controller="chat-scroll"
       data-chat-scroll-read-url-value="<%= read_conversation_path(@conversation) %>"
       class="flex-1 px-6 py-5 space-y-4 bg-stone-50/60 max-h-[32rem] overflow-y-auto">
    <% @messages.each do |message| %>
      <%= render "messages/message", message: message, current_user_id: current_user.id %>
    <% end %>
  </div>

  <%= render "conversations/read_state", conversation: @conversation, current_user: current_user, other_participant: @other_participant %>
  <%= render "messages/form", conversation: @conversation, message: @message %>
</section>
