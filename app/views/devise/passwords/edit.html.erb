<% content_for :title, "Reset password" %>

<div class="max-w-md mx-auto mt-12">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-serif font-semibold text-stone-900 mb-2">New password</h1>
    <p class="text-stone-500 text-sm">Almost there. Pick something you'll remember.</p>
  </div>

  <div class="bg-white border border-stone-200 rounded p-8">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= f.hidden_field :reset_password_token %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :password, "New password", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-stone-500 mt-1"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <%= f.submit "Change password",
            class: "w-full px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer font-medium" %>
    <% end %>
  </div>

  <div class="mt-6 text-center text-sm text-stone-500 space-y-2">
    <%= render "devise/shared/links" %>
  </div>
</div>