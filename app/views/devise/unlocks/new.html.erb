<% content_for :title, "Resend unlock instructions" %>

<div class="max-w-md mx-auto mt-12">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-serif font-semibold text-stone-900 mb-2">Unlock your account</h1>
    <p class="text-stone-500 text-sm">Too many failed logins will lock you out. We'll email you a link to unlock.</p>
  </div>

  <div class="bg-white border border-stone-200 rounded p-8">
    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <%= f.submit "Resend unlock instructions",
            class: "w-full px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer font-medium" %>
    <% end %>
  </div>

  <div class="mt-6 text-center text-sm text-stone-500 space-y-2">
    <%= render "devise/shared/links" %>
  </div>
</div>