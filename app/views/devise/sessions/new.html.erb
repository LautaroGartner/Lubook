<% content_for :title, "Log in" %>

<div class="max-w-md mx-auto mt-12">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-serif font-semibold text-stone-900 mb-2">Welcome back</h1>
    <p class="text-stone-500 text-sm">Log in to your Lubook account.</p>
  </div>

  <div class="bg-white border border-stone-200 rounded p-8">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2 text-sm text-stone-600">
          <%= f.check_box :remember_me, class: "rounded border-stone-300" %>
          <%= f.label :remember_me %>
        </div>
      <% end %>

      <%= f.submit "Log in",
            class: "w-full px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer font-medium" %>
    <% end %>
  </div>

  <div class="mt-6 text-center text-sm text-stone-500 space-y-2">
    <%= render "devise/shared/links" %>
  </div>
</div>