<% content_for :title, "Account settings" %>

<div class="max-w-md mx-auto mt-8">
  <div class="mb-8">
    <h1 class="text-3xl font-serif font-semibold text-stone-900 mb-2">Account settings</h1>
    <p class="text-stone-500 text-sm">Update your email, password, or leave Lubook.</p>
  </div>

  <div class="bg-white border border-stone-200 rounded p-8">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
          html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :username, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :username, autocomplete: "username",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.email_field :email, autocomplete: "email",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-xs text-rose-600 mt-1">Pending confirmation for <%= resource.unconfirmed_email %></p>
        <% end %>
      </div>

      <div class="pt-4 border-t border-stone-200">
        <p class="text-sm font-medium text-stone-700 mb-3">Change password</p>

        <div class="space-y-4">
          <div>
            <%= f.label :password, "New password", class: "block text-sm text-stone-600 mb-1" %>
            <%= f.password_field :password, autocomplete: "new-password",
                  class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-stone-500 mt-1">Leave blank to keep the same. Minimum <%= @minimum_password_length %> characters.</p>
            <% end %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm text-stone-600 mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
          </div>
        </div>
      </div>

      <div class="pt-4 border-t border-stone-200">
        <%= f.label :current_password, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.password_field :current_password, autocomplete: "current-password",
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
        <p class="text-xs text-stone-500 mt-1">We need your current password to save any changes.</p>
      </div>

      <div class="pt-4 border-t border-stone-200 space-y-4">
        <p class="text-sm font-medium text-stone-700">Chat privacy</p>

        <label class="flex items-start gap-3 rounded-lg border border-stone-200 px-4 py-3">
          <%= f.check_box :share_read_receipts, class: "mt-1 rounded border-stone-300 text-rose-500 focus:ring-rose-400" %>
          <span>
            <span class="block text-sm font-medium text-stone-800">Share read receipts</span>
            <span class="block text-xs text-stone-500 mt-1">Let people see when you've read their latest message.</span>
          </span>
        </label>

        <label class="flex items-start gap-3 rounded-lg border border-stone-200 px-4 py-3">
          <%= f.check_box :share_last_seen, class: "mt-1 rounded border-stone-300 text-rose-500 focus:ring-rose-400" %>
          <span>
            <span class="block text-sm font-medium text-stone-800">Share active status</span>
            <span class="block text-xs text-stone-500 mt-1">Show “Active now” or “Last active” in chats.</span>
          </span>
        </label>
      </div>

      <%= f.submit "Save changes",
            class: "w-full px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer font-medium" %>
    <% end %>
  </div>

  <div class="bg-white border border-red-200 rounded p-6 mt-8">
    <h2 class="text-sm font-semibold text-red-800 mb-1">Delete account</h2>
    <p class="text-sm text-stone-600 mb-4">
      This removes your profile, posts, comments, likes, and follows. Permanently. There's no undo.
    </p>
    <%= button_to "Delete my account", registration_path(resource_name),
          data: { turbo_confirm: "Are you sure? This cannot be undone." },
          method: :delete,
          class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition-colors cursor-pointer text-sm" %>
  </div>
</div>
