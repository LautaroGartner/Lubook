<div class="px-6 py-4 transition-colors <%= notification.read? ? "hover:bg-stone-50" : "bg-rose-50/60 hover:bg-rose-50" %>">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <% if notification.actionable_follow_request_for?(notification.recipient) %>
        <p class="text-sm text-stone-800"><%= notification.message %></p>
      <% else %>
        <%= link_to notification.message, notification.destination_path(self),
              class: "text-sm text-stone-800 hover:text-rose-700 transition-colors" %>
      <% end %>
      <p class="mt-1 text-xs text-stone-400">
        <%= time_ago_in_words(notification.created_at) %> ago
      </p>

      <% if notification.actionable_follow_request_for?(notification.recipient) %>
        <div class="mt-3 flex flex-wrap gap-2">
          <%= button_to "Accept", accept_follow_path(notification.notifiable), method: :patch,
                params: { notification_id: notification.id },
                class: "px-3 py-1.5 text-sm bg-stone-900 text-white rounded-full hover:bg-stone-800 transition-colors" %>
          <%= button_to "Reject", reject_follow_path(notification.notifiable), method: :patch,
                params: { notification_id: notification.id },
                class: "px-3 py-1.5 text-sm border border-stone-300 rounded-full hover:bg-stone-100 transition-colors" %>
        </div>
      <% end %>
    </div>

    <div class="flex items-center gap-3 flex-shrink-0">
      <% unless notification.read? %>
        <span class="inline-flex w-2.5 h-2.5 rounded-full bg-rose-500"></span>
      <% end %>
      <%= button_to "Clear", notification_path(notification), method: :delete,
            class: "text-xs text-stone-400 hover:text-stone-700 transition-colors" %>
    </div>
  </div>
</div>
