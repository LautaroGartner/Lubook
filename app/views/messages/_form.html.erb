<div id="message_form" class="border-t border-stone-200 px-6 py-4">
  <%= form_with model: [conversation, message], class: "space-y-3", data: { controller: "upload" } do |f| %>
    <%= f.hidden_field :reply_to_message_id, data: { message_form_target: "replyId" } %>
    <div data-message-form-target="replyPreview" class="<%= message.reply_to_message.present? ? "" : "hidden " %>rounded-2xl border border-stone-200 bg-stone-50 px-4 py-3">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <% reply_target = message.reply_to_message %>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Replying to</p>
          <p data-message-form-target="replyAuthor" class="mt-1 text-sm font-semibold text-stone-800"><%= reply_target&.user&.profile&.display_name.presence || reply_target&.user&.username %></p>
          <p data-message-form-target="replyBody" class="mt-1 text-sm text-stone-500 line-clamp-2">
            <% if reply_target&.body.present? %>
              <%= truncate(reply_target.body, length: 90) %>
            <% elsif reply_target&.image&.attached? %>
              Photo
            <% end %>
          </p>
        </div>
        <button type="button"
                data-action="message-form#clearReply"
                class="text-xs font-medium text-stone-400 hover:text-stone-700 transition-colors">
          Cancel
        </button>
      </div>
    </div>
    <%= f.text_area :body, rows: 3, placeholder: "Write a message...",
          data: { action: "keydown->message-form#submitOnEnter", message_form_target: "body" },
          class: "w-full px-3 py-2 border border-stone-300 rounded-lg resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>
    <div class="flex items-center justify-between gap-3">
      <div class="min-w-0">
        <label class="inline-flex items-center gap-2 px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded cursor-pointer transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span data-upload-target="filename" class="text-stone-500">Attach photo</span>
          <%= f.file_field :image, accept: "image/jpeg,image/png,image/webp,image/gif,image/heic,image/heif,image/svg+xml",
                class: "hidden",
                data: { action: "change->upload#preview" } %>
        </label>
      </div>
      <p class="hidden md:block text-xs text-stone-400 text-right">Enter to send, Shift+Enter for a new line.</p>
    </div>
    <% if message.errors.any? %>
      <p class="text-sm text-rose-600"><%= message.errors.full_messages.to_sentence %></p>
    <% end %>
    <div class="flex justify-end">
      <%= f.submit "Send", class: "px-4 py-2 bg-rose-500 text-white rounded-lg hover:bg-rose-600 transition-colors cursor-pointer text-sm" %>
    </div>
  <% end %>
</div>
