<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Lubook" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 min-h-screen"
        <% if user_signed_in? %>
          data-controller="turbo-poll"
          data-turbo-poll-url-value="<%= live_notifications_path(include_list: controller_name == "notifications") %>"
          data-turbo-poll-interval-value="15000"
        <% end %>>
    <% if user_signed_in? %>
      <%= turbo_stream_from [current_user, :notifications] %>
      <%= turbo_stream_from [current_user, :chats] %>
      <nav class="bg-white border-b border-stone-200 sticky top-0 z-10" data-controller="menu">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <%= link_to "Lubook", root_path,
          class: "text-3xl font-serif font-semibold tracking-tight text-stone-900 hover:text-rose-600 transition-colors" %>

    <!-- Desktop nav (hidden on mobile) -->
    <div class="hidden md:flex items-center gap-5 text-sm">
      <%= link_to "Feed", root_path,
            class: "text-stone-600 hover:text-rose-600 transition-colors" %>
      <%= link_to "People", users_path,
            class: "text-stone-600 hover:text-rose-600 transition-colors" %>
      <%= link_to conversations_path,
            class: "text-stone-600 hover:text-rose-600 transition-colors flex items-center gap-2" do %>
        <span>Chats</span>
        <%= render "shared/chat_badge", count: @unread_chats_count %>
      <% end %>
      <%= link_to notifications_path,
            class: "text-stone-600 hover:text-rose-600 transition-colors flex items-center gap-2" do %>
        <span>Notifications</span>
        <%= render "shared/notifications_badge", count: @unread_notifications_count %>
      <% end %>
      <%= link_to "Profile", user_path(current_user),
            class: "text-stone-600 hover:text-rose-600 transition-colors" %>
      <%= link_to "Settings", edit_user_registration_path,
            class: "text-stone-600 hover:text-rose-600 transition-colors" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "text-stone-400 hover:text-rose-600 transition-colors",
            form: { data: { turbo: false } } %>
    </div>

    <!-- Hamburger button (shown on mobile) -->
    <button type="button" data-action="click->menu#toggle"
            class="relative md:hidden text-stone-600 hover:text-rose-600 transition-colors p-2 -mr-2"
            aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <%= render "shared/notifications_badge",
            count: @unread_notifications_count,
            badge_id: "mobile_menu_notifications_badge",
            badge_classes: "absolute -right-1 -top-1 min-w-4 h-4 items-center justify-center rounded-full bg-rose-500 px-1 text-[10px] font-semibold text-white" %>
    </button>
  </div>

  <!-- Mobile dropdown (hidden by default) -->
  <div data-menu-target="panel" class="hidden md:hidden border-t border-stone-200 bg-white">
    <div class="max-w-4xl mx-auto px-4 py-2 flex flex-col">
      <%= link_to "Feed", root_path,
            class: "block py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100" %>
      <%= link_to "People", users_path,
            class: "block py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100" %>
      <%= link_to conversations_path,
            class: "py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100 flex items-center justify-between gap-3" do %>
        <span>Chats</span>
        <%= render "shared/chat_badge",
              count: @unread_chats_count,
              badge_id: "mobile_chat_badge",
              badge_classes: "min-w-5 h-5 items-center justify-center rounded-full bg-stone-900 px-1.5 text-[11px] font-semibold text-white" %>
      <% end %>
      <%= link_to notifications_path,
            class: "py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100 flex items-center justify-between gap-3" do %>
        <span>Notifications</span>
        <%= render "shared/notifications_badge",
              count: @unread_notifications_count,
              badge_id: "mobile_notifications_badge",
              badge_classes: "min-w-5 h-5 items-center justify-center rounded-full bg-rose-500 px-1.5 text-[11px] font-semibold text-white" %>
      <% end %>
      <%= link_to "Profile", user_path(current_user),
            class: "block py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100" %>
      <%= link_to "Settings", edit_user_registration_path,
            class: "block py-3 text-stone-700 hover:text-rose-600 transition-colors border-b border-stone-100" %>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "w-full text-left py-3 text-stone-500 hover:text-rose-600 transition-colors",
            form: { data: { turbo: false } } %>
    </div>
  </div>
</nav>
    <% end %>

    <% if notice %>
      <div class="max-w-4xl mx-auto mt-4 px-4">
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-2 rounded">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-4xl mx-auto mt-4 px-4">
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-2 rounded">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
