<% content_for :title, "Edit post" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-serif font-semibold text-stone-900">Edit post</h1>
  <%= link_to "Cancel", post_path(@post), class: "px-4 py-2 border border-stone-300 rounded hover:bg-stone-100 text-sm" %>
</div>

<%= form_with model: @post, multipart: true, class: "space-y-3 bg-white border border-stone-200 rounded p-6" do |f| %>
  <% if @post.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-2 rounded">
      <%= @post.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.text_area :body, rows: 4,
        class: "w-full px-3 py-2 border border-stone-300 rounded resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>

  <% if @post.images.attached? %>
    <div>
      <p class="text-xs text-stone-500 mb-2">Current images:</p>
      <div class="grid grid-cols-3 gap-2">
        <% @post.images.each do |img| %>
          <div class="relative">
            <%= image_tag img.variant(resize_to_limit: [400, 400]),
                  class: "rounded border border-stone-200 w-full aspect-square object-cover" %>
            <%= link_to "×", post_image_path(@post, img.id),
                  data: { turbo_method: :delete, turbo_confirm: "Remove this image?" },
                  class: "absolute top-1 right-1 w-6 h-6 rounded-full bg-black/60 text-white text-xs flex items-center justify-center hover:bg-black/80" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "posts/form",
        form: f,
        submit_button: f.submit("Save changes", class: "px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer text-sm shrink-0") %>
<% end %>
