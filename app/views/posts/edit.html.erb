<% content_for :title, "Edit post" %>

<h1 class="text-2xl font-bold mb-6">Edit post</h1>

<%= form_with model: @post, multipart: true, class: "space-y-3 bg-white border border-stone-200 rounded p-6" do |f| %>
  <% if @post.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-2 rounded">
      <%= @post.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.text_area :body, rows: 4,
        class: "w-full px-3 py-2 border border-stone-300 rounded resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>

  <% if @post.image.attached? %>
    <div>
      <p class="text-xs text-stone-500 mb-2">Current image:</p>
      <%= image_tag @post.image.variant(resize_to_limit: [400, 400]),
            class: "rounded border border-stone-200 max-h-48" %>
    </div>
  <% end %>

  <label class="inline-flex items-center gap-2 px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded cursor-pointer transition border border-stone-200 w-fit"
       data-controller="upload">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
  </svg>
  <span data-upload-label>Replace image</span>
  <%= f.file_field :image, accept: "image/jpeg,image/png,image/webp,image/gif",
        class: "hidden", data: { action: "change->upload#preview" } %>
  </label>

  <div class="flex gap-2">
    <%= f.submit "Save changes", class: "px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer text-sm" %>
    <%= link_to "Cancel", post_path(@post), class: "px-4 py-2 border border-stone-300 rounded hover:bg-stone-100 text-sm" %>
  </div>
<% end %>