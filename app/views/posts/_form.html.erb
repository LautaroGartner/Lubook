<%# Reusable multi-image upload widget. Pass `submit_button:` to embed it in the row. %>

<div data-controller="upload"
     data-upload-max-value="10"
     data-upload-direct-upload-url-value="<%= rails_direct_uploads_url %>"
     class="space-y-3">

  <div data-upload-target="previews" class="grid grid-cols-3 gap-2 empty:hidden"></div>
  <div data-upload-target="hiddenInputs" class="hidden"></div>

  <div class="flex items-center justify-between gap-3">
    <label for="<%= form.object_name %>_images_input"
           class="inline-flex items-center gap-2 px-3 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded cursor-pointer transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span data-upload-target="filename" class="text-stone-500">Add images</span>
    </label>

    <%= form.file_field :images,
          multiple: true,
          accept: "image/jpeg,image/png,image/webp,image/gif",
          id: "#{form.object_name}_images_input",
          class: "hidden",
          data: {
            upload_target: "input",
            action: "change->upload#picked"
          } %>

    <%= local_assigns[:submit_button] %>
  </div>
</div>
