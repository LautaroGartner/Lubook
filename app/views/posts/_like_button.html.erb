<%= turbo_frame_tag dom_id(post, :like) do %>
  <% if post.liked_by?(current_user) %>
    <%= button_to post_like_path(post), method: :delete,
          class: "flex items-center gap-1 text-rose-600 hover:text-rose-700 transition-all hover:scale-110 no-underline #{"animate-heart-pop" if local_assigns[:just_liked]}",
          form: { class: "inline" } do %>
      ♥ <%= post.likes.size %>
    <% end %>
  <% else %>
    <%= button_to post_like_path(post), method: :post,
          class: "flex items-center gap-1 text-stone-500 hover:text-rose-600 transition-all hover:scale-110 no-underline",
          form: { class: "inline" } do %>
      ♡ <%= post.likes.size %>
    <% end %>
  <% end %>
<% end %>