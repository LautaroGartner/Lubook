<% cache [post, "post-partial-v12"] do %>
<article class="bg-white border border-stone-200 rounded overflow-hidden max-w-[640px] mx-auto" data-controller="lightbox">
  <header class="flex items-start justify-between gap-4 p-6 pb-3">
    <div class="flex items-start gap-3 min-w-0">
      <% if post.user.profile&.avatar&.attached? %>
        <%= link_to user_path(post.user), class: "block flex-shrink-0 transition-transform hover:scale-105" do %>
          <%= image_tag post.user.profile.avatar.variant(resize_to_fill: [80, 80]),
                class: "w-10 h-10 rounded-full object-cover" %>
        <% end %>
      <% else %>
        <%= link_to user_path(post.user), class: "block flex-shrink-0 transition-transform hover:scale-105" do %>
          <div class="w-10 h-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold">
            <%= post.user.username.first.upcase %>
          </div>
        <% end %>
      <% end %>

      <div class="min-w-0">
        <%= link_to post.user.username, user_path(post.user),
              class: "font-semibold text-stone-900 hover:text-rose-600 transition-colors" %>
        <div class="text-xs text-stone-500">
          <time datetime="<%= post.created_at.iso8601 %>">
            <%= time_ago_in_words(post.created_at) %> ago
            <span class="text-stone-400">· <%= post.created_at.strftime("%b %-d, %Y") %></span>
          </time>
          <% if post.updated_at > post.created_at + 1.minute %>
            · <span>edited</span>
          <% end %>
        </div>
      </div>
    </div>

    <% if policy(post).update? %>
      <div class="flex flex-shrink-0 gap-3 text-xs">
        <%= link_to "Edit", edit_post_path(post),
          class: "text-stone-400 hover:text-rose-600 transition-colors" %>
        <%= button_to "Delete", post_path(post), method: :delete,
              data: { turbo_confirm: "Delete this post?" },
              class: "text-stone-400 hover:text-rose-600 transition-colors",
              form: { class: "inline" } %>
      </div>
    <% end %>
  </header>

  <% if post.body.present? %>
    <div class="prose-tight text-stone-800 leading-relaxed px-6 pb-3">
      <%= simple_format(post.body) %>
    </div>
  <% end %>

  <% if post.images.attached? %>
  <div data-controller="carrousel"
       data-action="focusin->carrousel#activate pointerenter->carrousel#activate keydown.left@window->carrousel#prev keydown.right@window->carrousel#next"
       tabindex="0"
       class="relative focus:outline-none">

    <div class="relative w-full overflow-hidden bg-stone-100 aspect-[4/5]">
      <% post.images.each_with_index do |img, i| %>
        <button type="button"
                data-carrousel-target="slide"
                data-action="click->carrousel#open"
                data-lightbox-full-url-value="<%= url_for(img) %>"
                class="<%= i.zero? ? 'block' : 'hidden' %> w-full h-full">
          <%= image_tag img.variant(resize_to_limit: [1200, 1500]),
                class: "w-full h-full object-cover block" %>
        </button>
      <% end %>

      <% if post.images.count > 1 %>
        <div class="absolute top-3 right-3 bg-black/70 text-white text-xs px-2.5 py-1 rounded-full font-medium pointer-events-none z-10">
          <span data-carrousel-target="counter">1</span> / <%= post.images.count %>
        </div>

        <button type="button"
                data-carrousel-target="prevBtn"
                data-action="carrousel#prev"
                class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center text-xl transition opacity-30 cursor-not-allowed z-10">‹</button>

        <button type="button"
                data-carrousel-target="nextBtn"
                data-action="carrousel#next"
                class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center text-xl transition z-10">›</button>

        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
          <% post.images.each_with_index do |_, i| %>
            <button type="button"
                    data-carrousel-target="dot"
                    data-action="carrousel#goto"
                    data-carrousel-index-param="<%= i %>"
                    class="w-2 h-2 rounded-full transition <%= i.zero? ? 'bg-white' : 'bg-white/60' %>"></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

  <div class="flex items-center gap-4 text-sm text-stone-600 px-6 py-3">
    <%= render "posts/like_button", post: post %>

    <%= link_to post_path(post), class: "flex items-center gap-1 text-stone-500 hover:text-rose-600 transition-colors" do %>
      💬 <%= post.comments.size %>
    <% end %>
  </div>
</article>
<% end %>
