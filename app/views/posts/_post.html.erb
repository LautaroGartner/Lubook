<% cache [post, "post-partial-v9"] do %>
<article class="bg-white border border-stone-200 rounded p-6" data-controller="lightbox">
  <header class="flex items-start justify-between gap-4 mb-3">
    <div class="flex items-start gap-3 min-w-0">
      <% if post.user.profile&.avatar&.attached? %>
        <%= link_to user_path(post.user), class: "block flex-shrink-0 transition-transform hover:scale-105" do %>
          <%= image_tag post.user.profile.avatar.variant(resize_to_fill: [80, 80]),
                class: "w-10 h-10 rounded-full object-cover" %>
        <% end %>
      <% else %>
        <%= link_to user_path(post.user), class: "block flex-shrink-0 transition-transform hover:scale-105" do %>
          <div class="w-10 h-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold">
            <%= post.user.username.first.upcase %>
          </div>
        <% end %>
      <% end %>

      <div class="min-w-0">
        <%= link_to post.user.username, user_path(post.user),
              class: "font-semibold text-stone-900 hover:text-rose-600 transition-colors" %>
        <div class="text-xs text-stone-500">
          <time datetime="<%= post.created_at.iso8601 %>">
            <%= time_ago_in_words(post.created_at) %> ago
            <span class="text-stone-400">· <%= post.created_at.strftime("%b %-d, %Y") %></span>
          </time>
          <% if post.updated_at > post.created_at + 1.minute %>
            · <span>edited</span>
          <% end %>
        </div>
      </div>
    </div>

    <% if policy(post).update? %>
      <div class="flex flex-shrink-0 gap-3 text-xs">
        <%= link_to "Edit", edit_post_path(post),
          class: "text-stone-400 hover:text-rose-600 transition-colors" %>
        <%= button_to "Delete", post_path(post), method: :delete,
              data: { turbo_confirm: "Delete this post?" },
              class: "text-stone-400 hover:text-rose-600 transition-colors",
              form: { class: "inline" } %>
      </div>
    <% end %>
  </header>

  <div class="prose-tight text-stone-800 leading-relaxed mt-2 mb-2">
    <%= simple_format(post.body) %>
  </div>

  <% if post.image.attached? %>
    <%= image_tag post.image.variant(resize_to_limit: [1600, 1600], saver: { quality: 85 }),
          class: "mt-3 max-w-full max-h-[32rem] object-contain cursor-zoom-in transition-opacity hover:opacity-95",
          data: {
            action: "click->lightbox#open",
            lightbox_full_url_value: url_for(post.image),
            post_image: true
          } %>
  <% end %>

  <div class="flex items-center gap-4 text-sm text-stone-600 pt-3 mt-1">
    <%= render "posts/like_button", post: post %>

    <%= link_to post_path(post), class: "flex items-center gap-1 text-stone-500 hover:text-rose-600 transition-colors" do %>
      💬 <%= post.comments.size %>
    <% end %>
  </div>
</article>
<% end %>
