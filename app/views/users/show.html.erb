<% content_for :title, @user.username %>

<div class="bg-white border border-stone-200 rounded p-6 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="flex gap-4 items-start">
      <% if @user.profile&.avatar&.attached? %>
        <%= image_tag @user.profile.avatar.variant(resize_to_fill: [192, 192]),
              class: "w-20 h-20 rounded-full object-cover border border-stone-200 flex-shrink-0 cursor-zoom-in",
              data: {
                controller: "lightbox",
                action: "click->lightbox#open",
                lightbox_full_url_value: url_for(@user.profile.avatar)
              } %>
      <% else %>
        <div class="w-20 h-20 rounded-full bg-stone-200 flex items-center justify-center text-3xl text-stone-600 font-semibold flex-shrink-0">
          <%= @user.username.first.upcase %>
        </div>
      <% end %>

      <div class="min-w-0">
        <h1 class="text-2xl sm:text-4xl font-serif font-semibold text-stone-900 leading-tight">
          <%= @user.profile&.display_name.presence || @user.username %>
        </h1>
        <p class="text-stone-500 text-sm">@<%= @user.username %></p>
        <% if @user.profile&.bio.present? %>
          <p class="mt-3 text-stone-700 text-sm leading-relaxed"><%= @user.profile.bio %></p>
        <% end %>
        <% if @user.profile&.location.present? %>
          <p class="mt-2 text-xs text-stone-500">📍 <%= @user.profile.location %></p>
        <% end %>
      </div>
    </div>

    <div class="flex-shrink-0">
      <% if @is_self %>
        <%= link_to "Edit profile", edit_user_profile_path(@user),
              class: "inline-block px-4 py-2 border border-rose-200 text-rose-700 rounded text-sm hover:bg-rose-50 transition-colors" %>
      <% elsif current_user.connected_with?(@user) %>
        <div class="flex flex-wrap gap-2">
          <%= button_to "Message", conversations_path(user_id: @user.id),
                class: "px-4 py-2 bg-stone-900 text-white rounded text-sm hover:bg-stone-800 transition-colors" %>
          <% if @follow.nil? %>
            <%= button_to "Follow", follows_path(receiver_id: @user.id),
                  class: "px-4 py-2 bg-rose-500 text-white rounded text-sm hover:bg-rose-600 transition-colors" %>
          <% elsif @follow.pending? %>
            <%= button_to "Cancel request", follow_path(@follow), method: :delete,
                  class: "px-4 py-2 border border-stone-300 text-stone-600 rounded text-sm hover:bg-stone-100 transition-colors" %>
          <% elsif @follow.accepted? %>
            <%= button_to "Unfollow", follow_path(@follow), method: :delete,
                  class: "px-4 py-2 border border-stone-300 rounded text-sm hover:bg-stone-100 transition-colors" %>
          <% end %>
        </div>
      <% elsif @follow.nil? %>
        <%= button_to "Follow", follows_path(receiver_id: @user.id),
              class: "px-4 py-2 bg-rose-500 text-white rounded text-sm hover:bg-rose-600 transition-colors" %>
      <% elsif @follow.pending? %>
        <%= button_to "Cancel request", follow_path(@follow), method: :delete,
              class: "px-4 py-2 border border-stone-300 text-stone-600 rounded text-sm hover:bg-stone-100 transition-colors" %>
      <% elsif @follow.accepted? %>
        <%= button_to "Unfollow", follow_path(@follow), method: :delete,
              class: "px-4 py-2 border border-stone-300 rounded text-sm hover:bg-stone-100 transition-colors" %>
      <% end %>
    </div>
  </div>

  <div class="flex gap-6 mt-6 pt-6 border-t border-stone-200 text-sm">
    <%= link_to followers_user_path(@user), class: "hover:text-stone-900" do %>
      <span class="font-bold"><%= @user.cached_followers_count %></span>
      <span class="text-stone-500">followers</span>
    <% end %>
    <%= link_to following_user_path(@user), class: "hover:text-stone-900" do %>
      <span class="font-bold"><%= @user.cached_following_count %></span>
      <span class="text-stone-500">following</span>
    <% end %>
  </div>
</div>

<% if @posts.any? %>
  <div class="space-y-6">
    <%= render @posts %>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <div class="bg-white border border-stone-200 rounded p-12 text-center text-stone-500">
    <% if current_user == @user %>
      <p class="text-lg font-serif text-stone-700 mb-2">You haven't posted yet.</p>
      <p class="text-sm">Head <%= link_to "home", root_path, class: "text-rose-600 hover:text-rose-700 transition-colors" %> to share your first thought.</p>
    <% else %>
      <p class="text-lg font-serif text-stone-700 mb-2">Nothing here yet.</p>
      <p class="text-sm"><%= @user.username %> hasn't posted anything — check back soon.</p>
    <% end %>
  </div>
<% end %>
