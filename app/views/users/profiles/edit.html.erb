<% content_for :title, "Edit profile" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-serif font-semibold text-stone-900 mb-6">Edit profile</h1>

  <%= form_with model: @profile, url: user_profile_path(@user), method: :patch,
        multipart: true, class: "space-y-6", data: { controller: "upload" } do |f| %>
    <% if @profile.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
        <%= @profile.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="bg-white border border-stone-200 rounded p-6">
      <label class="block text-sm font-medium text-stone-700 mb-3">Avatar</label>
      <div class="flex items-center gap-5">
        <% if @profile.avatar.attached? %>
          <%= image_tag @profile.avatar.variant(resize_to_limit: [120, 120]),
                class: "w-20 h-20 rounded-full object-cover border border-stone-200" %>
        <% else %>
          <div class="w-20 h-20 rounded-full bg-stone-200 flex items-center justify-center text-stone-500 text-2xl font-semibold">
            <%= @user.username.first.upcase %>
          </div>
        <% end %>

        <div>
          <%= f.label :avatar, "Choose new avatar",
                class: "inline-flex items-center gap-2 px-4 py-2 border border-rose-200 text-rose-700 rounded text-sm hover:bg-rose-50 transition-colors cursor-pointer" %>
          <%= f.file_field :avatar,
                accept: "image/jpeg,image/png,image/webp,image/gif",
                class: "hidden",
                data: { action: "change->upload#preview", upload_target: "input" } %>
          <p class="text-xs text-stone-500 mt-2" data-upload-target="filename">JPEG, PNG, WEBP, or GIF. Max 10MB.</p>
        </div>
      </div>
    </div>

    <div class="bg-white border border-stone-200 rounded p-6 space-y-4">
      <div>
        <%= f.label :display_name, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :display_name,
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>

      <div>
        <%= f.label :bio, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_area :bio, rows: 4,
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
        <p class="text-xs text-stone-500 mt-1">Up to 500 characters.</p>
      </div>

      <div>
        <%= f.label :location, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :location,
              class: "w-full px-3 py-2 border border-stone-300 rounded focus:outline-none focus:ring-2 focus:ring-rose-400 transition-colors" %>
      </div>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Save changes",
            class: "px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer font-medium" %>
      <%= link_to "Cancel", user_path(@user),
            class: "px-4 py-2 border border-stone-300 text-stone-600 rounded hover:bg-stone-100 transition-colors" %>
    </div>
  <% end %>
</div>