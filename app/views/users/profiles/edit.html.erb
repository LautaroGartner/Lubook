<% content_for :title, "Edit profile" %>

<h1 class="text-2xl font-bold mb-6">Edit profile</h1>

<%= form_with model: @profile, url: user_profile_path(@user), method: :patch,
      multipart: true, class: "space-y-4" do |f| %>
  <% if @profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-2 rounded">
      <%= @profile.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <label class="block text-sm font-medium mb-1">Avatar</label>
    <% if @profile.avatar.attached? %>
      <%= image_tag @profile.avatar.variant(resize_to_limit: [120, 120]),
            class: "w-24 h-24 rounded-full object-cover mb-2 border border-stone-200" %>
    <% end %>
    <%= f.file_field :avatar, accept: "image/jpeg,image/png,image/webp,image/gif",
          class: "block text-sm" %>
    <p class="text-xs text-stone-500 mt-1">JPEG, PNG, WEBP, or GIF. Max 5MB.</p>
  </div>

  <div>
    <%= f.label :display_name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :display_name, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div>
    <%= f.label :bio, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :bio, rows: 4, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
    <p class="text-xs text-stone-500 mt-1">Up to 500 characters.</p>
  </div>

  <div>
    <%= f.label :location, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :location, class: "w-full px-3 py-2 border border-stone-300 rounded" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: "px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", user_path(@user), class: "px-4 py-2 border border-stone-300 rounded hover:bg-stone-100" %>
  </div>
<% end %>

<div class="mt-12 pt-6 border-t border-red-200">
  <h2 class="text-lg font-semibold text-red-900 mb-2">Danger zone</h2>
  <p class="text-sm text-stone-600 mb-4">
    Deleting your account will permanently remove your profile, posts, comments, likes, and follows. This cannot be undone.
  </p>
  <%= button_to "Delete my account",
        registration_path(current_user),
        method: :delete,
        data: { turbo_confirm: "This will permanently delete your account and all your content. Continue?" },
        class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 cursor-pointer text-sm" %>
</div>