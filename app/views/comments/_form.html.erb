<%= turbo_frame_tag "comment_form" do %>
  <%= form_with model: comment, url: post_comments_path(post), class: "mb-6 rounded-2xl border border-stone-200 bg-stone-50 p-4" do |f| %>
    <%= f.text_area :body, rows: 3, placeholder: "Add a comment... Use @username to mention someone",
          class: "w-full bg-transparent px-0 py-0 border-0 resize-none focus:outline-none focus:ring-0 text-stone-900 placeholder:text-stone-400" %>
    <% if comment.errors.any? %>
      <p class="mt-2 text-sm text-rose-600"><%= comment.errors.full_messages.to_sentence %></p>
    <% end %>
    <div class="mt-3 flex items-center justify-between">
      <p class="text-xs text-stone-400">Keep it light, honest, and fun.</p>
      <%= f.submit "Post", class: "px-4 py-2 bg-stone-900 text-white rounded-full hover:bg-stone-800 transition-colors cursor-pointer text-sm font-medium" %>
    </div>
  <% end %>
<% end %>
