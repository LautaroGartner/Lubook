<%= turbo_frame_tag "comment_form" do %>
  <%= form_with model: comment, url: post_comments_path(post), class: "mb-6" do |f| %>
    <%= f.text_area :body, rows: 2, placeholder: "Write a comment...",
          class: "w-full px-3 py-2 border border-stone-300 rounded resize-none focus:outline-none focus:ring-2 focus:ring-stone-400" %>
    <div class="mt-2 flex justify-end">
      <%= f.submit "Comment", class: "px-4 py-2 bg-rose-500 text-white rounded hover:bg-rose-600 transition-colors cursor-pointer text-sm" %>
    </div>
  <% end %>
<% end %>