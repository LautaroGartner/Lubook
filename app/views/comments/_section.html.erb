<div id="post_comments_section" class="mt-6 bg-white border border-stone-200 rounded-3xl p-6 shadow-sm">
  <div class="flex items-center justify-between gap-3 mb-5">
    <div>
      <h2 class="text-lg font-semibold text-stone-900">Comments</h2>
      <p class="text-sm text-stone-500">Jump into the conversation.</p>
    </div>
    <span class="text-sm font-medium text-stone-400"><%= pluralize(post.comments.count, "comment") %></span>
  </div>

  <% if user_signed_in? %>
    <%= render "comments/form", post: post, comment: comment %>
  <% end %>

  <div id="comments" class="space-y-4">
    <% comments.select { |item| item.parent_id.nil? }.each do |comment_item| %>
      <%= render "comments/comment_thread", comment: comment_item, post: post, all_comments: comments, expanded_thread_ids: local_assigns.fetch(:expanded_thread_ids, []) %>
    <% end %>
  </div>

  <% if comments.none? { |item| item.parent_id.nil? } %>
    <p class="text-stone-500 text-sm mt-4">No comments yet. Be the first.</p>
  <% end %>
</div>
